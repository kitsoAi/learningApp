# Single Next.js app auth/security
SECRET_KEY=change-this-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend/API
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_PUOSPEECH_URL=http://localhost:3001
NEXT_PUBLIC_PUOSPEECH_API_URL=http://localhost:3001

# Database
# Use the pooled database URL in Vercel. Neon pooled URLs work well in serverless.
POSTGRES_PRISMA_URL=postgresql://user:password@ep-example-pooler.region.neon.tech/dbname?sslmode=require
POSTGRES_URL=postgresql://user:password@ep-example-pooler.region.neon.tech/dbname?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://user:password@ep-example.region.neon.tech/dbname?sslmode=require
# Common provider alternatives also supported:
DATABASE_URL=
DATABASE_URL_UNPOOLED=
POSTGRES_URL_NO_SSL=
# Parts-based fallback also supported:
POSTGRES_DATABASE=
POSTGRES_HOST=
POSTGRES_USER=
POSTGRES_PASSWORD=
PGDATABASE=
PGHOST=
PGHOST_UNPOOLED=
PGUSER=
PGPASSWORD=
POSTGRES_CONNECT_TIMEOUT=10
POSTGRES_IDLE_TIMEOUT=20
POSTGRES_MAX_LIFETIME=300
POSTGRES_POOL_MAX=2

# File storage
# Create a public Vercel Blob store connected to this project.
BLOB_READ_WRITE_TOKEN=
