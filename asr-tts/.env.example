# Service URL used by learningApp frontend
NEXT_PUBLIC_PUOSPEECH_URL=http://localhost:3001

# Build config (set to your ASR/TTS source folder)
PUOSPEECH_BUILD_CONTEXT=../puo_speaker/backend
PUOSPEECH_DOCKERFILE=Dockerfile
PUOSPEECH_IMAGE=puospeech:local
PUOSPEECH_PORT=3001

# Runtime model config
ASR_MODEL_PATH=/app/models/whisper-small-ct2
XTTS_MODEL_DIR=/app/xtts_fine_tuned
ASR_API_KEY=change-me

# Optional host mounts for local/dev
MODEL_VOLUME_HOST=./models
XTTS_VOLUME_HOST=./xtts_fine_tuned
